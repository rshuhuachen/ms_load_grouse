library(dplyr); library(data.table); library(readr); library(brms)
load(file = "data/phenotypes/phenotypes_annual.RData")
# load mutation load measures
load("output/load/all_loads_combined_da_nosex_29scaf_plus_per_region.RData") #loads no sex chr only 30 scaf
method="gerp45"
# subset only the relevant method/loadtype
load <- load_per_region %>% filter(loadtype == method)
# merge files
pheno <- left_join(pheno_long, load, by = "id")
pheno$born <- pheno$year - pheno$age
pheno <- pheno %>% mutate(age_cat = as.factor(case_when(age == 1 ~ "yearling", age > 1  ~ "adult")))
library(dplyr); library(data.table); library(readr); library(brms)
method="gerp45"
load(file = "data/phenotypes/phenotypes_annual.RData")
# load mutation load measures
load("output/load/all_loads_combined_da_nosex_29scaf_plus_per_region.RData") #loads no sex chr only 30 scaf
# subset only the relevant method/loadtype
load <- load_per_region %>% filter(loadtype == method)
# merge files
pheno <- left_join(pheno_long, load, by = "id")
pheno$born <- pheno$year - pheno$age
pheno <- pheno %>% mutate(age_cat = as.factor(case_when(age == 1 ~ "yearling", age > 1  ~ "adult")))
### modelling ####
formula <- formula(paste0("scale(", response, ") ~ scale(total_load) + age_cat + (1|year) + (1|site/id)"))
response="attend"
### modelling ####
formula <- formula(paste0("scale(", response, ") ~ scale(total_load) + age_cat + (1|year) + (1|site/id)"))
ggplot(pheno, aes(x=attend)) + geom_histogram()
library(tidyverse)
ggplot(pheno, aes(x=attend)) + geom_histogram()
fit <- brm(formula,
family = "beta",
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
### run brms model ####
iter = 1000000
burn = 500000
thin = 1000
fit <- brm(formula,
family = "beta",
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
iterations=iter
fit <- brm(formula,
family = "beta",
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
summary(pheno$attend)
formula <- formula(paste0(response ~ scale(total_load) + age_cat + (1|year) + (1|site/id)"))
formula <- formula(response ~ scale(total_load) + age_cat + (1|year) + (1|site/id)"))
formula <- formula(paste0(response, " ~ scale(total_load) + age_cat + (1|year) + (1|site/id)"))
fit <- brm(formula,
family = "beta",
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
formula
summary(pheno$formula)
summary(pheno$attend)
fit <- brm(attend ~ scale(total_load) + age_cat + (1|year) + (1|site/id),
family = zero_one_inflated_beta(),
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
summary(fit)
pp_check(fit)
fit_zoib <- fit
load("output/models/annual/traits/model_attend_gerp45.RData")
fit_g <- fit
pp_check(fit_g)
pp_check(fit_g, type="bar")
pp_check(fit_g, type="bars")
fit_g <- add_criterion(fit_g, c("loo"))
fit_zoib<- add_criterion(fit_zoib, c("loo"))
loo_compare(fit_g, fit_zoib)
summary(fit_zoib)
mcmc_areas(fit_g, pars=c("b_scaletotal_load"))
mcmc_areas(fit_g, prob=0.8,prob_outer=0.95,pars=c("b_scaletotal_load"))
mcmc_areas(fit_zoib, prob=0.8,prob_outer=0.95,pars=c("b_scaletotal_load"))
mcmc_intervals_data(fit_zoib, prob=0.8,prob_outer=0.95,pars=c("b_scaletotal_load"))
mcmc_intervals_data(fit_zoib, prob=0.9,prob_outer=0.95,pars=c("b_scaletotal_load"))
pp_check(fit_zoib)
pp_check(fit_zoib,ndraws=100)
load(file = "data/phenotypes/phenotypes_annual.RData")
# load mutation load measures
load("output/load/all_loads_combined_da_nosex_29scaf_plus_per_region.RData") #loads no sex chr only 30 scaf
# subset only the relevant method/loadtype
load <- load_per_region %>% filter(loadtype == method)
# merge files
pheno <- left_join(pheno_long, load, by = "id")
pheno$born <- pheno$year - pheno$age
pheno <- pheno %>% mutate(age_cat = as.factor(case_when(age == 1 ~ "yearling", age > 1  ~ "adult")))
### modelling ####
formula <- formula("MS ~ scale(total_load) + scale(lyre) + scale(eyec) + scale(blue) + scale(dist) + scale(attend) + scale(fight) + age_cat + (1|year) + (1|site/id)")
ggplot(pheno, aes(x=MS)) + geom_histogram()
fit <- brm(formula,
family = negbinomial(),
data = pheno,
cores =8,
control = list(adapt_delta = 0.99, max_treedepth = 15),
prior = prior(normal(0,1), class = b),
iter = iterations,
thin = thin, warmup = burn)
summary(fit)
### load packages ####
pacman::p_load(brms, bayesplot, tidyverse, ggridges, prismatic, ggpubr,
extrafont, cowplot, performance, data.table, effects)
source("scripts/theme_ggplot.R")
